# Copy this file to .env (gitignored) and fill in the values.
# Same set must be added to Cloudflare Pages dashboard → Settings → Environment variables.

# Supabase ---------------------------------------------------------------
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# "Publishable key" in Supabase dashboard (starts with sb_publishable_...).
# Safe to expose to the browser.
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# "Secret key" in Supabase dashboard (starts with sb_secret_...).
# Server-only — bypasses RLS, never expose to the browser.
SUPABASE_SECRET_KEY=sb_secret_...

# OpenAI moderation (free endpoint) --------------------------------------
OPENAI_API_KEY=sk-...

# TMDB ------------------------------------------------------------------
TMDB_API_KEY=your-tmdb-v3-api-key

# PostHog ---------------------------------------------------------------
PUBLIC_POSTHOG_KEY=phc_...
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stable salt for IP+UA hashing — generate with: openssl rand -hex 16
DAILY_HASH_SALT=replace-me-with-32-char-random-string

# Admin allowlist (comma-separated). Mirror in admin_emails table.
ADMIN_EMAILS=chevaliertgf@gmail.com

# Public site URL (used in magic-link redirect + OG tags)
PUBLIC_SITE_URL=http://localhost:5173

# Optional: Cloudflare Turnstile (anti-bot on submit)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
